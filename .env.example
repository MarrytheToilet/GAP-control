# GAP-Control environment. Copy to `.env` and fill in. `.env` is gitignored.
# The synthesis client is OpenAI-compatible (works with OpenAI, DeepSeek, Qwen/DashScope
# compatible-mode, vLLM/SGLang servers, OpenRouter, etc.).

# --- LLM API for synthetic data generation & LLM-judge filtering ---
GAPCTRL_API_KEY=sk-your-api-key-here
GAPCTRL_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
GAPCTRL_MODEL=
# 可用的模型包括qwen3.6-flash、deepseek-v4-flash、kimi-k2.6、glm-5.2、MiniMax-M2.5
# optional separate (cheaper/stronger) model used only for the judge/filter step
GAPCTRL_JUDGE_MODEL=

# --- generation controls for synthesis ---
GAPCTRL_SYNTH_TEMPERATURE=1.0
GAPCTRL_SYNTH_MAX_TOKENS=256
GAPCTRL_SYNTH_CONCURRENCY=8

# --- local model roots (so we never hit the network) ---
GAPCTRL_MODELS_DIR=/home/hanyu/models
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
